# ── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=blog_db
MYSQL_USER=blog_user
MYSQL_PASSWORD=blog_password

# ── Ollama models ──────────────────────────────────────────────────────────────
# Used by the textgen microservice and pulled by ollama-init on first start
RESEARCH_MODEL=llama3.2
WRITING_MODEL=mistral

# ── imagegen microservice ─────────────────────────────────────────────────────
# HuggingFace model ID for Stable Diffusion (diffusers-compatible repo)
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
# Optional: HuggingFace token (needed only for gated / private models)
HF_TOKEN=

# ── Internal service URLs (Docker Compose resolves these automatically) ────────
# Do NOT change these unless you rename the compose services
TEXTGEN_URL=http://textgen:8000
IMAGEGEN_URL=http://imagegen:8001
