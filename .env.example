# ── Gemini API (text generation) ──────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default text model
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Vertex AI (image generation) ──────────────────────────────────────────────
# Your Google Cloud project ID
GCP_PROJECT_ID=your-project-id

# Region where Imagen is available (default: us-central1)
GCP_LOCATION=us-central1

# Preferred Imagen model — agent falls back automatically if unavailable
IMAGEN_MODEL=imagen-3.0-generate-001

# ── Vertex AI Authentication ───────────────────────────────────────────────────
# Path to your service account JSON key file (mounted into the container).
# Leave blank if running on GCP with Workload Identity.
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json

# ── Facebook (Graph API) ───────────────────────────────────────────────────────
# Generate a Page Access Token in Meta for Developers → your App → Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_ACCESS_TOKEN=your_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# ── Twitter / X (OAuth 1.0a) ───────────────────────────────────────────────────
# Create credentials at https://developer.twitter.com/en/portal/dashboard
# App must have Read + Write permissions
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# ── Instagram (Graph API via Facebook) ────────────────────────────────────────
# Use the same Facebook App that manages the Instagram Business account
# Required permissions: instagram_basic, instagram_content_publish
# The Account ID is the numeric Instagram Business/Creator account ID
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# ── Google Business Profile (My Business API v4) ──────────────────────────────
# Obtain a bearer token via Google OAuth Playground (https://developers.google.com/oauthplayground)
# Scope: https://www.googleapis.com/auth/business.manage
# Account ID format:  accounts/1234567890
# Location ID format: locations/0987654321
GOOGLE_BUSINESS_ACCESS_TOKEN=your_google_business_oauth_token_here
GOOGLE_BUSINESS_ACCOUNT_ID=accounts/your_account_id_here
GOOGLE_BUSINESS_LOCATION_ID=locations/your_location_id_here
