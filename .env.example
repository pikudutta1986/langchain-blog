# ── Gemini API (text generation) ──────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default text model
GEMINI_TEXT_MODEL=gemini-2.0-flash

# ── Vertex AI (image generation) ──────────────────────────────────────────────
# Your Google Cloud project ID
GCP_PROJECT_ID=your-project-id

# Region where Imagen is available (default: us-central1)
GCP_LOCATION=us-central1

# Preferred Imagen model — agent falls back automatically if unavailable
IMAGEN_MODEL=imagen-3.0-generate-001

# ── Vertex AI Authentication ───────────────────────────────────────────────────
# Path to your service account JSON key file (mounted into the container).
# Leave blank if running on GCP with Workload Identity.
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service_account.json
